# Provider keys. All optional - providers without a key are skipped, the rest still work.
# You need at least one. Groq is the easiest place to start.

GROQ_API_KEY=
GOOGLE_AISTUDIO_API_KEY=
CEREBRAS_API_KEY=
OLLAMA_API_KEY=
OPENROUTER_API_KEY=

# Cloudflare Workers AI needs both
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=

# Artificial Analysis intelligence index.
#
# NOT optional in practice. Without it the market does not "lose an axis" - it becomes MEANINGLESS:
# every model falls back to a size heuristic (params x log(context)), so the biggest model ranks #1
# and every dimension scores the same. Production shipped without this key and looked fine.
#
# WARNING - there are TWO env files and it is a trap:
#   .env.local    read by docker-compose and the frontend build
#   backend/.env  read by load_dotenv() when the backend runs from its own directory
# A key that lives in only one of them will be missed when provisioning a host. Set BOTH, and check
# GET /health - it now reports `degraded` when a key like this is absent.
AA_API_KEY=

# Lock the proxy behind a bearer token. Leave unset for open local use.
LOCAL_API_KEY=
